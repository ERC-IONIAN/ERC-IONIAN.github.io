<div class="flex items-center gap-1 theme-toggle">
  <button
    data-set-theme="light"
    class="btn btn-ghost btn-sm btn-circle theme-btn"
    title="Light mode"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="5"></circle>
      <path
        d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"
      ></path>
    </svg>
  </button>
  <button
    data-set-theme="dark"
    class="btn btn-ghost btn-sm btn-circle theme-btn"
    title="Dark mode"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
</div>

<script>
  function updateActiveThemeBtn() {
    const current =
      document.documentElement.getAttribute('data-theme') || 'light';
    document.querySelectorAll('.theme-btn').forEach((btn) => {
      const isActive = btn.getAttribute('data-set-theme') === current;
      btn.classList.toggle('text-warning', isActive);
      btn.classList.toggle('opacity-40', !isActive);
    });
  }
  updateActiveThemeBtn();
  const observer = new MutationObserver(updateActiveThemeBtn);
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
</script>
