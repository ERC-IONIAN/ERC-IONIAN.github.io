---
import ThemeSelector from './ThemeSelector.astro';

const siteTitle = "IONIAN";
const nav = [
  { title: "Home", url: "/" },
  { title: "Team", url: "/team/" },
  { title: "Publications", url: "/publications/" },
  { title: "Projects", url: "/projects/" },
  { title: "Labs", url: "/labs/" },
  { title: "Resources", url: "/resources/" },
];
---

<nav class="navbar bg-neutral text-neutral-content sticky top-0 z-[60] px-4">
  <div class="navbar-start">
    <a class="flex items-center text-lg font-bold gap-2 no-underline text-neutral-content" href="/">
      <div class="w-7 h-7 rounded-full bg-base-300 flex-shrink-0"></div>
      {siteTitle}
    </a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-8 text-base">
      {nav.map(item => (
        <li>
          <a href={item.url}>{item.title}</a>
        </li>
      ))}
    </ul>
  </div>
  <div class="navbar-end gap-2">
    <ThemeSelector />
    <div class="dropdown dropdown-end lg:hidden">
      <label tabindex="0" class="btn btn-ghost btn-sm">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-50 p-2 shadow bg-neutral text-neutral-content rounded-box w-52">
        {nav.map(item => (
          <li><a href={item.url}>{item.title}</a></li>
        ))}
      </ul>
    </div>
  </div>
</nav>
