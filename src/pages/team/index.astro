---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const roleOrder: Record<string, number> = {
  Professor: 0,
  'Post Doc Researcher': 1,
  'PhD Candidate': 2,
  'Research Scientist': 3,
};

const members = (await getCollection('team')).sort(
  (a, b) =>
    (roleOrder[a.data.role ?? ''] ?? 99) - (roleOrder[b.data.role ?? ''] ?? 99),
);
---

<BaseLayout title="Team">
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href="/images/nikos_circle.jpg"
      fetchpriority="high"
    />
  </Fragment>
  <!-- Banner (will be replaced with an image) -->
  <div class="page-banner">
    <div class="page-banner-bg"></div>
    <div class="page-banner-overlay"></div>
    <h1 class="page-banner-title">Meet Our Team!</h1>
  </div>

  <div class="page-wrapper">
    <div class="team-grid">
      {
        members.map((m, i) => {
          const pic = m.data.image?.thumbnail || m.data.author?.picture;
          // First row (4 cols on desktop) is above-the-fold — eager-load
          // and prioritize so the LCP image lands fast.
          const eager = i < 4;
          return (
            <a class="team-member" href={m.data.website || `/team/${m.slug}/`}>
              {pic && (
                <img
                  class="team-pic"
                  src={pic}
                  alt={m.data.title}
                  width="240"
                  height="300"
                  loading={eager ? 'eager' : 'lazy'}
                  fetchpriority={eager ? 'high' : 'auto'}
                  decoding="async"
                />
              )}
              <span class="team-name">{m.data.title}</span>
              {m.data.role && <span class="team-role">{m.data.role}</span>}
            </a>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
