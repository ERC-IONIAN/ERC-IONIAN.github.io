---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { iconSvgs } from '../../utils/icons';

const roleOrder: Record<string, number> = {
  Professor: 0,
  'Post Doc Researcher': 1,
  'PhD Candidate': 2,
  'Research Scientist': 3,
};

const members = (await getCollection('team')).sort(
  (a, b) =>
    (roleOrder[a.data.role ?? ''] ?? 99) - (roleOrder[b.data.role ?? ''] ?? 99),
);

const ALLOWED_ICONS = new Set(['scholar', 'linkedin', 'github']);
---

<BaseLayout title="Team">
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href="/images/nikos_circle.jpg"
      fetchpriority="high"
    />
  </Fragment>
  <!-- Banner -->
  <div class="page-banner">
    <div class="page-banner-bg"></div>
    <div class="page-banner-overlay"></div>
    <h1 class="page-banner-title">Meet Our Team!</h1>
  </div>

  <div class="page-wrapper">
    <div class="team-grid">
      {
        members.map((m, i) => {
          const pic = m.data.image?.thumbnail || m.data.author?.picture;
          const eager = i < 4;
          const socialLinks = (m.data.author?.links ?? []).filter(
            (l) => l.icon && ALLOWED_ICONS.has(l.icon),
          );
          const website = m.data.website;
          return (
            <div class="team-member">
              {pic && (
                <img
                  class="team-pic"
                  src={pic}
                  alt={m.data.title}
                  width="240"
                  height="300"
                  loading={eager ? 'eager' : 'lazy'}
                  fetchpriority={eager ? 'high' : 'auto'}
                  decoding="async"
                />
              )}
              <span class="team-name">{m.data.title}</span>
              {m.data.role && <span class="team-role">{m.data.role}</span>}
              {(socialLinks.length > 0 || website) && (
                <div class="team-icons">
                  {website && (
                    <a
                      href={website}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={`${m.data.title} — Personal website`}
                      aria-label={`${m.data.title} — Personal website`}
                      class="team-icon"
                    >
                      <Fragment set:html={iconSvgs.website} />
                    </a>
                  )}
                  {socialLinks.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={link.title}
                      aria-label={`${m.data.title} — ${link.title}`}
                      class="team-icon"
                    >
                      {link.icon && iconSvgs[link.icon] && (
                        <Fragment set:html={iconSvgs[link.icon]} />
                      )}
                    </a>
                  ))}
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
