---
import MemberLayout from '../../../layouts/MemberLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const roleOrder: Record<string, number> = {
    Professor: 0,
    'Post Doc Researcher': 1,
    'PhD Candidate': 2,
    'Research Scientist': 3,
  };
  const members = (await getCollection('team')).sort(
    (a, b) =>
      (roleOrder[a.data.role ?? ''] ?? 99) -
      (roleOrder[b.data.role ?? ''] ?? 99),
  );
  return members.map((m, i) => ({
    params: { slug: m.slug },
    props: {
      member: m,
      prev: members[i - 1] ?? null,
      next: members[i + 1] ?? null,
    },
  }));
}

const { member, prev, next } = Astro.props;
const author = member.data.author;
const pic = author?.picture || member.data.image?.thumbnail;
const education = member.data.education ?? [];
const experience = member.data.experience ?? [];
const service = member.data.service ?? [];
---

<MemberLayout
  title={`CV — ${member.data.title}`}
  memberName={member.data.title}
  memberRole={member.data.role}
  memberPic={pic}
  memberAffiliation={member.data.affiliation}
  slug={member.slug}
  links={author?.links}
  activeTab="cv"
>
  <!-- Education -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 border-b border-base-300 pb-2">
      Education
    </h2>
    {
      education.length > 0 ? (
        <ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical">
          {education.map((edu, i) => (
            <li>
              {i > 0 && <hr class="bg-accent" />}
              <div class="timeline-middle">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-5 w-5 text-accent"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
              <div
                class={`${i % 2 === 0 ? 'timeline-start md:text-end' : 'timeline-end'} mb-10`}
              >
                <time class="font-mono italic">{edu.years}</time>
                <div class="text-lg font-black">{edu.degree}</div>
                <div>{edu.institution}</div>
                <div class="opacity-60">{edu.location}</div>
              </div>
              {i < education.length - 1 && <hr class="bg-accent" />}
            </li>
          ))}
        </ul>
      ) : (
        <p class="opacity-60">Education information to be added.</p>
      )
    }
  </section>

  <!-- Experience -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 border-b border-base-300 pb-2">
      Experience
    </h2>
    {
      experience.length > 0 ? (
        <ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical">
          {experience.map((exp, i) => (
            <li>
              {i > 0 && <hr class="bg-secondary" />}
              <div class="timeline-middle">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-5 w-5 text-secondary"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
              <div
                class={`${i % 2 === 0 ? 'timeline-start md:text-end' : 'timeline-end'} mb-10`}
              >
                <time class="font-mono italic">{exp.years}</time>
                <div class="text-lg font-black">{exp.title}</div>
                <div>{exp.institution}</div>
                <div class="opacity-60">{exp.location}</div>
              </div>
              {i < experience.length - 1 && <hr class="bg-secondary" />}
            </li>
          ))}
        </ul>
      ) : (
        <p class="opacity-60">Experience information to be added.</p>
      )
    }
  </section>

  <!-- Professional Service -->
  {
    service.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6 border-b border-base-300 pb-2">
          Professional Service
        </h2>
        <ul class="list-disc list-inside space-y-2 opacity-80">
          {service.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    )
  }

  <nav class="flex justify-between pt-6 border-t border-base-300 gap-4">
    {
      prev && (
        <a
          href={`/team/${prev.slug}/cv/`}
          class="nav-prev-next flex-1 flex flex-col p-4 rounded-lg border border-base-300 transition-all no-underline"
        >
          <span class="text-xs opacity-50 mb-1">&larr; Previous</span>
          <span class="font-semibold">{prev.data.title}</span>
        </a>
      )
    }
    {
      next && (
        <a
          href={`/team/${next.slug}/cv/`}
          class="nav-prev-next flex-1 flex flex-col items-end p-4 rounded-lg border border-base-300 transition-all text-right no-underline"
        >
          <span class="text-xs opacity-50 mb-1">Next &rarr;</span>
          <span class="font-semibold">{next.data.title}</span>
        </a>
      )
    }
  </nav>
</MemberLayout>
