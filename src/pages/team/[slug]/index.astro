---
import MemberLayout from '../../../layouts/MemberLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const roleOrder: Record<string, number> = {
    "Professor": 0, "Post Doc Researcher": 1, "PhD Candidate": 2, "Research Scientist": 3,
  };
  const members = (await getCollection('team')).sort((a, b) =>
    (roleOrder[a.data.role ?? ''] ?? 99) - (roleOrder[b.data.role ?? ''] ?? 99)
  );
  return members.map((m, i) => ({
    params: { slug: m.slug },
    props: {
      member: m,
      prev: members[i - 1] ?? null,
      next: members[i + 1] ?? null,
    },
  }));
}

const { member, prev, next } = Astro.props;
const author = member.data.author;
const pic = author?.picture || member.data.image?.thumbnail;

const iconSvgs: Record<string, string> = {
  email: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`,
  twitter: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22.46 6c-.77.35-1.6.58-2.46.69a4.3 4.3 0 001.88-2.38 8.59 8.59 0 01-2.72 1.04 4.28 4.28 0 00-7.32 3.91A12.16 12.16 0 013.16 4.86a4.28 4.28 0 001.32 5.71 4.24 4.24 0 01-1.94-.53v.05a4.28 4.28 0 003.43 4.19 4.28 4.28 0 01-1.93.07 4.29 4.29 0 004 2.97A8.59 8.59 0 012 19.54a12.13 12.13 0 006.56 1.92c7.88 0 12.2-6.53 12.2-12.2 0-.19 0-.37-.01-.56A8.72 8.72 0 0024 5.06a8.57 8.57 0 01-2.54.7z"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>`,
  scholar: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>`,
  orcid: `<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-3.919-3.722h-2.4z"/></svg>`,
};
---

<MemberLayout
  title={member.data.title}
  memberName={member.data.title}
  memberRole={member.data.role}
  memberPic={pic}
  memberAffiliation={member.data.affiliation}
  slug={member.slug}
  links={author?.links}
  activeTab="home"
>
  <!-- Hero -->
  <section class="flex flex-col md:flex-row items-center gap-10 border-b border-base-300 pb-10 mb-10">
    <div class="flex-1">
      <h1 class="text-4xl font-bold mb-3">
        Hi, I'm <span class="text-secondary">{member.data.title}</span>
      </h1>
      {member.data.role && (
        <p class="text-xl opacity-60 mb-2">{member.data.role} at IONIAN, ETRO, VUB</p>
      )}
      {member.data.affiliation && (
        <p class="text-base opacity-50 mb-4">{member.data.affiliation}</p>
      )}
      <p class="text-lg mb-5">
        Brief impactful description of research focus and academic mission.
        Highlight key contributions and areas of expertise.
      </p>
      {author?.links && (
        <div class="flex gap-3 flex-wrap">
          {author.links.map(link => (
            <a
              href={link.url}
              target="_blank"
              title={link.title}
              class="size-10 inline-flex items-center justify-center rounded-xl hover:bg-primary/20 transition-all duration-300"
            >
              {link.icon && iconSvgs[link.icon]
                ? <Fragment set:html={iconSvgs[link.icon]} />
                : link.title
              }
            </a>
          ))}
        </div>
      )}
    </div>
    {pic && (
      <div class="size-56 lg:block hidden flex-shrink-0">
        <img src={pic} alt={member.data.title} class="w-full h-full mask mask-circle object-cover" />
      </div>
    )}
  </section>

  <!-- Research Areas -->
  <section class="py-10 border-b border-base-300">
    <h2 class="text-3xl font-bold mb-8">Research Areas</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="p-6 rounded-lg member-card">
        <h3 class="text-xl font-semibold mb-3">Area 1</h3>
        <p>Brief description of the research interest</p>
      </div>
      <div class="p-6 rounded-lg member-card">
        <h3 class="text-xl font-semibold mb-3">Area 2</h3>
        <p>Brief description of the research interest</p>
      </div>
    </div>
  </section>

  <!-- Recent Publications -->
  <section class="py-10">
    <h2 class="text-3xl font-bold mb-8">Recent Publications</h2>
    <p class="opacity-60">Publications to be added.</p>
  </section>

  <!-- Prev / Next -->
  <nav class="flex justify-between pt-6 border-t border-base-300 gap-4">
    {prev && (
      <a href={`/team/${prev.slug}/`} class="nav-prev-next flex-1 flex flex-col p-4 rounded-lg border border-base-300 transition-all no-underline">
        <span class="text-xs opacity-50 mb-1">&larr; Previous</span>
        <span class="font-semibold">{prev.data.title}</span>
      </a>
    )}
    {next && (
      <a href={`/team/${next.slug}/`} class="nav-prev-next flex-1 flex flex-col items-end p-4 rounded-lg border border-base-300 transition-all text-right no-underline">
        <span class="text-xs opacity-50 mb-1">Next &rarr;</span>
        <span class="font-semibold">{next.data.title}</span>
      </a>
    )}
  </nav>
</MemberLayout>
