---
import BaseLayout from '../layouts/BaseLayout.astro';

const newsItems = [
  {
    date: 'Mar 2025',
    tag: 'Publication',
    title: '2 papers accepted at CVPR 2025',
    description:
      'One paper at CVPR Findings and one at the CVPR Workshop on Distillation of Foundation Models for Autonomous Driving.',
    link: '/publications/',
  },
  {
    date: 'Jan 2025',
    tag: 'Project',
    title: 'ENACT Horizon Europe project kicks off',
    description:
      'IONIAN joins the ENACT consortium on explainable AI for health applications (2025–2028).',
    link: 'https://enact-he.eu/',
  },
  {
    date: 'Oct 2024',
    tag: 'Grant',
    title: 'ERC Consolidator Grant awarded',
    description:
      'Nikos Deligiannis receives a 2024 ERC Consolidator Grant for research on interpretable AI and multiterminal compression for autonomous vehicles.',
    link: 'https://www.vub.be/en/news/two-vub-researchers-receive-prestigious-erc-consolidator-grant-for-pioneering-research',
  },
  {
    date: 'Aug 2024',
    tag: 'Award',
    title: 'Best Student Paper at EUSIPCO 2024',
    description:
      'Esther Rodrigo Bonet wins the Best Student Paper Award for "Physics-Guided Graph Convolutional Deep Equilibrium Networks for Environmental Data".',
    link: '/team/esther_rodrigo/',
  },
];

const tagColors: Record<string, string> = {
  Publication: 'badge-primary',
  Talk: 'badge-secondary',
  Project: 'badge-accent',
  Grant: 'badge-warning',
  Award: 'badge-success',
};

const author = {
  name: 'Nikos Deligiannis',
  picture: '/images/nikos_circle.jpg',
};
---

<BaseLayout>
  <!-- Banner (will be replaced with a gif) -->
  <div class="banner-wrapper">
    <div class="banner-placeholder"></div>
    <!-- Dark Gradient Overlay -->
    <div class="banner-overlay"></div>
    <!-- Content -->
    <div class="banner-content">
      <h1 class="banner-title">Interpretable & Explainable AI Research</h1>
      <p class="banner-subtitle">We are IONIAN Group at VUB-ETRO</p>
      <div class="banner-actions">
        <a href="/team/" class="banner-btn">Meet the Team</a>
      </div>
    </div>
    <!-- Scroll Indicator -->
    <div class="banner-scroll">
      <svg
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>

  <div class="page-wrapper">
    <div class="flex flex-col items-center mb-6">
      <h1
        class="text-3xl font-bold mt-4"
        style="font-family: 'Lora', Georgia, serif;"
      >
        IONIAN Team
      </h1>
    </div>

    <div class="home-author-card">
      <a href="/team/nikos_deligiannis/">
        <img class="home-author-pic" src={author.picture} alt={author.name} />
      </a>
      <div class="home-author-name">
        <em>by</em>
        <a href="/team/nikos_deligiannis/">{author.name}</a>
      </div>
      <ul class="home-author-links">
        <li>
          <a
            href="mailto:Nikos.Deligiannis@vub.be"
            target="_blank"
            title="Email"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"
              ><path
                d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
              ></path></svg
            >
          </a>
        </li>
        <li>
          <a
            href="https://linkedin.com/in/nikos-deligiannis-a3b70a18"
            target="_blank"
            title="LinkedIn"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"
              ><path
                d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"
              ></path></svg
            >
          </a>
        </li>
        <li>
          <a
            href="http://scholar.google.gr/citations?user=iUGMLcYAAAAJ&hl=el&oi=ao"
            target="_blank"
            title="Google Scholar"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"
              ><path
                d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"
              ></path></svg
            >
          </a>
        </li>
        <li>
          <a href="https://github.com/ndeligia" target="_blank" title="GitHub">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
          </a>
        </li>
      </ul>
    </div>

    <div class="prose max-w-none mx-auto text-center">
      <p>
        The IONIAN group at <a href="https://www.etrovub.be" target="_blank"
          >ETRO</a
        >, <a href="https://www.vub.be" target="_blank"
          >Vrije Universiteit Brussel (VUB)</a
        > carries out research in <strong
          >interpretable machine learning, signal processing, and explainable AI</strong
        >. The group is headed by <a href="/team/nikos_deligiannis/"
          >Nikos Deligiannis</a
        > and is part of the Department of Electronics and Informatics (ETRO) at VUB,
        and affiliated to <a href="https://www.imec.be" target="_blank">imec</a
        >, Belgium.
      </p>

      <div class="not-prose home-hub-row">
        <a
          href="https://github.com/ERC-IONIAN"
          target="_blank"
          rel="noopener noreferrer"
          class="home-hub-card"
          title="Our code on GitHub"
        >
          <span class="home-hub-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
          </span>
          <span class="home-hub-label">Software</span>
          <span class="home-hub-sub">Our code on GitHub</span>
        </a>

        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="home-hub-card"
          title="Our datasets on Zenodo"
        >
          <span class="home-hub-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path
                d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"></path><path
                d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"></path></svg
            >
          </span>
          <span class="home-hub-label">Datasets</span>
          <span class="home-hub-sub">Our releases on Zenodo</span>
        </a>
      </div>

      <h2>Nikos Deligiannis</h2>
      <p>
        <a href="/team/nikos_deligiannis/">Nikos Deligiannis</a> is a Professor at
        <a href="https://www.etrovub.be" target="_blank">ETRO</a>, <a
          href="https://www.vub.be"
          target="_blank">VUB</a
        >, the holder of the 2024–2025 Francqui Research Professorship on
        Trustworthy AI, and a Principal Investigator at <a
          href="https://www.imec.be"
          target="_blank">imec</a
        >, Belgium. He received a <strong>2024 ERC Consolidator Grant</strong> to
        conduct research at the intersection between interpretable/explainable AI
        and multiterminal compression for autonomous vehicles. His current research
        focuses on interpretable and explainable AI, multidimensional signal processing,
        computer vision, and distributed/federated AI for automotive and healthcare
        applications.
      </p>
      <p>
        He received his Diploma in Electrical and Computer Engineering from the <a
          href="https://www.upatras.gr/en/"
          target="_blank">University of Patras</a
        >, Greece (2006) and his Ph.D. in Engineering Sciences from <a
          href="https://www.vub.be"
          target="_blank">VUB</a
        > (2012). From 2013 to 2015, he was a Senior Researcher at <a
          href="https://www.ucl.ac.uk"
          target="_blank">University College London</a
        >, UK. He is a member of IEEE and EURASIP, served as Chair of the
        EURASIP Technical Area Committee on Signal and Data Analytics for
        Machine Learning (2021–2023), and serves as an Associate Editor for the
        IEEE Transactions on Image Processing.
      </p>
    </div>

    <!-- News Feed -->
    <div class="mt-12 mb-6">
      <h2
        class="text-3xl font-bold text-center mb-8"
        style="font-family: 'Lora', Georgia, serif;"
      >
        Latest News
      </h2>
      <div class="news-feed" id="news-feed">
        {
          newsItems.map((item, i) => (
            <div class="news-item" data-news-index={i}>
              <div class="news-date">
                <span class="font-mono text-sm opacity-50">{item.date}</span>
                <span
                  class={`badge ${tagColors[item.tag] || 'badge-ghost'} badge-sm`}
                >
                  {item.tag}
                </span>
              </div>
              <div class="news-content">
                {item.link ? (
                  <a href={item.link} class="news-title">
                    {item.title}
                  </a>
                ) : (
                  <span class="news-title">{item.title}</span>
                )}
                <p class="news-desc">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <div class="news-pagination" id="news-pagination"></div>
    </div>

    <!-- Sponsors / Funders -->
    <section class="sponsors-section">
      <h2
        class="text-2xl font-bold text-center mb-8"
        style="font-family: 'Lora', Georgia, serif;"
      >
        Supported by
      </h2>
      <div class="sponsors-row">
        <a
          href="https://www.imec.be"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="imec"
        >
          <img src="/images/sponsors/imec.png" alt="imec" loading="lazy" />
        </a>
        <a
          href="https://erc.europa.eu/"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="European Research Council (ERC)"
        >
          <img
            src="/images/sponsors/erc.png"
            alt="European Research Council"
            loading="lazy"
          />
        </a>
        <a
          href="https://www.francquifoundation.be/"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="Fondation Francqui — Francqui Stichting"
        >
          <img
            src="/images/sponsors/francqui.png"
            alt="Fondation Francqui — Francqui Stichting"
            loading="lazy"
          />
        </a>
        <a
          href="https://www.fwo.be/"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="Research Foundation Flanders (FWO)"
        >
          <img
            src="/images/sponsors/fwo.png"
            alt="Research Foundation Flanders (FWO)"
            loading="lazy"
          />
        </a>
        <a
          href="https://innoviris.brussels/"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="Innoviris"
        >
          <img
            src="/images/sponsors/innoviris.svg"
            alt="Innoviris"
            loading="lazy"
          />
        </a>
        <a
          href="https://www.flandersairesearch.be/en"
          target="_blank"
          rel="noopener noreferrer"
          class="sponsor-logo"
          title="Flanders AI Research Programme"
        >
          <img
            src="/images/sponsors/flanders_ai.png"
            alt="Flanders AI Research Programme"
            loading="lazy"
          />
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const PER_PAGE = 3;
  let currentPage = 1;
  const items = document.querySelectorAll('.news-item');
  const totalPages = Math.max(1, Math.ceil(items.length / PER_PAGE));
  const pagination = document.getElementById('news-pagination');

  function render() {
    const start = (currentPage - 1) * PER_PAGE;
    const end = start + PER_PAGE;
    items.forEach((el, i) => {
      (el as HTMLElement).style.display = i >= start && i < end ? '' : 'none';
    });
    renderPagination();
  }

  function renderPagination() {
    if (!pagination || totalPages <= 1) return;
    pagination.innerHTML = '';

    const prev = document.createElement('button');
    prev.textContent = '\u2190 Newer';
    prev.className = 'news-page-btn';
    prev.disabled = currentPage <= 1;
    prev.addEventListener('click', () => {
      currentPage--;
      render();
    });
    pagination.appendChild(prev);

    const info = document.createElement('span');
    info.className = 'news-page-info';
    info.textContent = `${currentPage} / ${totalPages}`;
    pagination.appendChild(info);

    const next = document.createElement('button');
    next.textContent = 'Older \u2192';
    next.className = 'news-page-btn';
    next.disabled = currentPage >= totalPages;
    next.addEventListener('click', () => {
      currentPage++;
      render();
    });
    pagination.appendChild(next);
  }

  render();
</script>
