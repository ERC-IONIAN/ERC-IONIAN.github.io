---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTopics = (await getCollection('topics')).sort((a, b) =>
  (a.data.date?.getTime() ?? 0) - (b.data.date?.getTime() ?? 0)
);

export async function getStaticPaths() {
  const topics = (await getCollection('topics')).sort((a, b) =>
    (a.data.date?.getTime() ?? 0) - (b.data.date?.getTime() ?? 0)
  );
  return topics.map((t, i) => ({
    params: { slug: t.slug },
    props: {
      topic: t,
      prev: topics[i - 1] ?? null,
      next: topics[i + 1] ?? null,
    },
  }));
}

const { topic, prev, next } = Astro.props;
const { Content } = await topic.render();
const img = topic.data.image?.path;
---

<BaseLayout title={topic.data.title}>
  <div class="page-wrapper">
    <h1 class="page-title">{topic.data.title}</h1>
    <div style="width: 100%; aspect-ratio: 2/1; margin-bottom: 1.5rem; border-radius: 6px; overflow: hidden; background: oklch(0.93 0 0);">
      {img && img !== '/images/empty_banner.png' && <img src={img} alt={topic.data.title} style="width: 100%; height: 100%; object-fit: cover;" />}
    </div>
    <div class="prose max-w-none">
      <Content />
    </div>

    <nav class="page-nav">
      {prev && (
        <a class="page-nav-prev" href={`/topics/${prev.slug}/`}>
          <span class="page-nav-label">&larr; Previous</span>
          <span class="page-nav-title">{prev.data.title}</span>
        </a>
      )}
      {next && (
        <a class="page-nav-next" href={`/topics/${next.slug}/`}>
          <span class="page-nav-label">Next &rarr;</span>
          <span class="page-nav-title">{next.data.title}</span>
        </a>
      )}
    </nav>
  </div>
</BaseLayout>
