---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources">
  <div class="page-wrapper">
    <h1 class="page-title">Resources</h1>

    <div class="res-tabs">
      <div class="res-tab-bar">
        <button class="res-tab active" data-tab="equipments">Equipments</button>
        <button class="res-tab" data-tab="software">Software</button>
        <button class="res-tab" data-tab="datasets">Datasets</button>
        <button class="res-tab" data-tab="tutorials">Tutorials</button>
      </div>

      <!-- ==================== EQUIPMENTS ==================== -->
      <div class="res-panel active" data-panel="equipments">
        <!-- Stats banner -->
        <div
          class="stats stats-vertical lg:stats-horizontal w-full mb-10 border border-base-300"
        >
          <div class="stat">
            <div class="stat-title">GPU Tiers</div>
            <div class="stat-value text-primary">4</div>
            <div class="stat-desc">Desktop to Tier-1 supercompute</div>
          </div>
          <div class="stat">
            <div class="stat-title">Desktop GPUs</div>
            <div class="stat-value text-secondary">24+</div>
            <div class="stat-desc">RTX 3090, 2080 Ti, 1080 Ti</div>
          </div>
          <div class="stat">
            <div class="stat-title">AV Testbed Nodes</div>
            <div class="stat-value text-accent">3</div>
            <div class="stat-desc">Vehicle, RSU, Aerial drone</div>
          </div>
          <div class="stat">
            <div class="stat-title">Sensors</div>
            <div class="stat-value">15+</div>
            <div class="stat-desc">Cameras, LiDAR, event, IMU</div>
          </div>
        </div>

        <!-- Sub-category tabs -->
        <div class="eq-tab-bar">
          <button class="eq-tab active" data-eqtab="compute"
            >Compute Infrastructure</button
          >
          <button class="eq-tab" data-eqtab="testbed">IONIAN Testbed</button>
          <button class="eq-tab" data-eqtab="sensing">Sensing Equipment</button>
        </div>

        <!-- ---- Compute Infrastructure ---- -->
        <div class="eq-panel active" data-eqpanel="compute">
          <p class="text-base opacity-70 mb-8 max-w-3xl">
            VUB-ETRO provides a multi-tier compute infrastructure — from desktop
            GPUs for interactive development, through local and institutional
            GPU clusters, up to Flemish supercomputing resources.
          </p>

          <div class="grid gap-6">
            <!-- Desktop GPUs -->
            <div class="eq-card">
              <div class="eq-card-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z"
                  ></path>
                </svg>
              </div>
              <div class="eq-card-body">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">Desktop GPUs</h3>
                  <span class="badge badge-ghost">Interactive</span>
                </div>
                <p class="opacity-70 mb-4">
                  Dedicated workstations for interactive coding, prototyping,
                  and testing.
                </p>
                <div class="overflow-x-auto">
                  <table class="table table-xs">
                    <thead><tr><th>GPU</th><th>Qty</th><th>VRAM</th></tr></thead
                    >
                    <tbody>
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/geforce/graphics-cards/30-series/rtx-3090-3090ti/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/rtx-3090.jpg"
                            >NVIDIA RTX 3090</a
                          ></td
                        ><td>14</td><td>24 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/nl-nl/geforce/20-series/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/rtx-2080ti.png"
                            >NVIDIA RTX 2080 Ti</a
                          ></td
                        ><td>7</td><td>11 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/geforce/products/10series/ultimate-4k/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/gtx-1080ti.png"
                            >NVIDIA GeForce GTX 1080 Ti</a
                          ></td
                        ><td>2</td><td>11 GB</td></tr
                      >
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Lambda Servers -->
            <div class="eq-card">
              <div class="eq-card-icon eq-icon-secondary">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z"
                  ></path>
                </svg>
              </div>
              <div class="eq-card-body">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">Lambda Servers</h3>
                  <span class="badge badge-ghost">Dedicated</span>
                </div>
                <p class="opacity-70 mb-4">
                  Multi-GPU deep learning servers for training workloads.
                </p>
                <div class="overflow-x-auto">
                  <table class="table table-xs">
                    <thead><tr><th>Configuration</th><th>Qty</th></tr></thead>
                    <tbody>
                      <tr><td>Lambda Server (4x RTX 2080 Ti)</td><td>3</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Tier-3 Cluster -->
            <div class="eq-card">
              <div class="eq-card-icon eq-icon-accent">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v.878m-18-3A2.25 2.25 0 0 0 1.5 12v.878m0 0c.235-.083.487-.128.75-.128h19.5c.263 0 .515.045.75.128m-21 0A2.25 2.25 0 0 0 0 15v3a2.25 2.25 0 0 0 2.25 2.25h19.5A2.25 2.25 0 0 0 24 18v-3a2.25 2.25 0 0 0-1.5-2.122"
                  ></path>
                </svg>
              </div>
              <div class="eq-card-body">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">ETRO GPU Cluster</h3>
                  <span class="badge badge-primary">Tier-3</span>
                </div>
                <p class="opacity-70 mb-4">
                  On-demand computing cluster managed by VUB-ETRO for research
                  workloads.
                </p>
                <div class="overflow-x-auto">
                  <table class="table table-xs">
                    <thead><tr><th>GPU</th><th>Qty</th><th>VRAM</th></tr></thead
                    >
                    <tbody>
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/a100/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/a100.png"
                            >NVIDIA A100 Tensor Core</a
                          ></td
                        ><td>4</td><td>40 / 80 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/nl-nl/geforce/graphics-cards/40-series/rtx-4090/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/rtx-4090.png"
                            >NVIDIA GeForce RTX 4090</a
                          ></td
                        ><td>4</td><td>24 GB</td></tr
                      >
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Tier-2 -->
            <div class="eq-card">
              <div class="eq-card-logo">
                <a href="https://hpc.vub.be/" target="_blank"
                  ><img src="/images/vub-hpc-logo.png" alt="VUB HPC" /></a
                >
              </div>
              <div class="eq-card-body">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">
                    <a
                      href="https://hpc.vub.be/"
                      target="_blank"
                      class="link link-hover"
                      >VUB Institutional Cluster (Hydra)</a
                    >
                  </h3>
                  <span class="badge badge-secondary">Tier-2</span>
                </div>
                <p class="opacity-70 mb-4">
                  Maintained by the <a
                    href="https://www.vscentrum.be/"
                    target="_blank"
                    class="link link-hover"
                    >Flemish Supercomputer Centre (VSC)</a
                  >. 95% of jobs start within 8 hours. VUB-ETRO has priority
                  access to 2 H200 nodes.
                </p>
                <div class="overflow-x-auto">
                  <table class="table table-xs">
                    <thead
                      ><tr><th>GPU</th><th>Nodes</th><th>VRAM</th></tr></thead
                    >
                    <tbody>
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/a100/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/a100.png"
                            >NVIDIA A100</a
                          ></td
                        ><td>15</td><td>40 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/a100/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/a100.png"
                            >NVIDIA A100</a
                          ></td
                        ><td>5</td><td>80 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/h200/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/h200.png"
                            >NVIDIA H200</a
                          ></td
                        ><td>10</td><td>141 GB</td></tr
                      >
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Tier-1 -->
            <div class="eq-card">
              <div class="eq-card-logo">
                <div class="flex flex-col gap-2">
                  <a href="https://www.vscentrum.be/" target="_blank"
                    ><img src="/images/vsc-logo.png" alt="VSC" /></a
                  >
                  <a
                    href="https://press.vub.ac.be/press-release-vub-inaugurates-new-flemish-tier-1-supercomputer-sofia"
                    target="_blank"
                    ><img
                      src="/images/sofia-supercomputer.png"
                      alt="Sofia Supercomputer"
                    /></a
                  >
                </div>
              </div>
              <div class="eq-card-body">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">
                    <a
                      href="https://docs.vscentrum.be/gent/tier1_hortense.html"
                      target="_blank"
                      class="link link-hover">Flemish Tier-1 (Hortense)</a
                    > & <a
                      href="https://press.vub.ac.be/press-release-vub-inaugurates-new-flemish-tier-1-supercomputer-sofia"
                      target="_blank"
                      class="link link-hover">Sofia</a
                    >
                  </h3>
                  <span class="badge badge-accent">Tier-1</span>
                </div>
                <p class="opacity-70 mb-4">
                  Free access to Flemish Tier-1 via compute project submission. <a
                    href="https://press.vub.ac.be/press-release-vub-inaugurates-new-flemish-tier-1-supercomputer-sofia"
                    target="_blank"
                    class="link link-hover">Sofia</a
                  >, VUB's new Tier-1 supercomputer, has been operational since
                  November 2025.
                </p>
                <div class="overflow-x-auto">
                  <table class="table table-xs">
                    <thead><tr><th>GPU</th><th>Qty</th><th>VRAM</th></tr></thead
                    >
                    <tbody>
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/a100/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/a100.png"
                            >NVIDIA A100</a
                          > (Hortense)</td
                        ><td>80</td><td>40 GB</td></tr
                      >
                      <tr
                        ><td
                          ><a
                            href="https://www.nvidia.com/en-us/data-center/a100/"
                            target="_blank"
                            class="link link-hover eq-preview"
                            data-preview="/images/equipment/a100.png"
                            >NVIDIA A100</a
                          > (Hortense)</td
                        ><td>80</td><td>80 GB</td></tr
                      >
                      <tr
                        ><td colspan="3" class="italic opacity-60"
                          >Sofia specs TBA</td
                        ></tr
                      >
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ---- IONIAN Testbed ---- -->
        <div class="eq-panel" data-eqpanel="testbed">
          <p class="text-base opacity-70 mb-8 max-w-3xl">
            The ERC IONIAN testbed is a cooperative perception platform
            combining an instrumented vehicle, a roadside unit (RSU), and an
            aerial drone node for research on cooperative sensing, multimodal
            fusion, and intelligent machine perception.
          </p>

          <!-- Vehicle -->
          <div class="eq-card mb-6">
            <div class="eq-card-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H21M3.375 14.25h17.25M3.375 14.25V6.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v7.875m-13.5 0h6.375"
                ></path>
              </svg>
            </div>
            <div class="eq-card-body">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xl font-bold">Instrumented Vehicle</h3>
                <span class="badge badge-primary">Mobile</span>
              </div>
              <p class="opacity-70 mb-4">
                The instrumented car is equipped with multimodal sensors and
                on-board edge AI for real-time perception.
              </p>
              <div class="overflow-x-auto">
                <table class="table table-xs">
                  <thead
                    ><tr><th>Component</th><th>Model</th><th>Details</th></tr
                    ></thead
                  >
                  <tbody>
                    <tr
                      ><td>Cameras</td><td
                        >4x <a
                          href="https://www.baslerweb.com/en/shop/aca1920-50gc/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/basler-ace.jpg"
                          >Basler ace acA1920-50gc</a
                        ></td
                      ><td>Multi-view RGB</td></tr
                    >
                    <tr
                      ><td>LiDAR</td><td
                        ><a
                          href="https://www.robosense.ai/en/rslidar/Helios"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/robosense-helios.png"
                          >RoboSense Helios</a
                        ></td
                      ><td>32-beam spinning</td></tr
                    >
                    <tr
                      ><td>IMU</td><td
                        ><a
                          href="https://www.xsens.com/products/sensor-modules/xsens-mti-600-series-flexible-reliable-imus-for-all-design-needs"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/xsens-imu.jpg"
                          >Xsens AHRS/IMU</a
                        ></td
                      ><td>Automotive-grade</td></tr
                    >
                    <tr
                      ><td>Edge Compute</td><td
                        ><a
                          href="https://www.nvidia.com/en-us/autonomous-machines/embedded-systems/jetson-thor/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/jetson-thor.jpg"
                          >NVIDIA Jetson Thor</a
                        ></td
                      ><td>Dev kit</td></tr
                    >
                    <tr
                      ><td>Networking</td><td>PoE++</td><td
                        >+ dedicated power + NVMe storage</td
                      ></tr
                    >
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- RSU -->
          <div class="eq-card mb-6">
            <div class="eq-card-icon eq-icon-secondary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z"
                ></path>
              </svg>
            </div>
            <div class="eq-card-body">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xl font-bold">Roadside Unit (RSU)</h3>
                <span class="badge badge-secondary">Static</span>
              </div>
              <p class="opacity-70 mb-4">
                A fixed multimodal sensing setup for infrastructure-side
                perception, including a neuromorphic event camera.
              </p>
              <div class="overflow-x-auto">
                <table class="table table-xs">
                  <thead
                    ><tr><th>Component</th><th>Model</th><th>Details</th></tr
                    ></thead
                  >
                  <tbody>
                    <tr
                      ><td>Cameras</td><td
                        >4x <a
                          href="https://www.baslerweb.com/en/shop/aca1920-40gc/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/basler-ace.jpg"
                          >Basler ace acA1920-40gc</a
                        ></td
                      ><td>With C11-0824-12M-P lenses</td></tr
                    >
                    <tr
                      ><td>LiDAR</td><td
                        ><a
                          href="https://ouster.com/products/hardware/os1-lidar-sensor"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/ouster-os1.jpg"
                          >Ouster OS1-64 Gen 2</a
                        ></td
                      ><td>64-channel digital</td></tr
                    >
                    <tr
                      ><td>Event Camera</td><td
                        ><a
                          href="https://www.prophesee.ai/event-camera-evk4/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/prophesee-evk4.jpg"
                          >Prophesee EVK4 HD</a
                        ></td
                      ><td>Neuromorphic, high-res</td></tr
                    >
                    <tr
                      ><td>Edge Compute</td><td
                        ><a
                          href="https://www.nvidia.com/en-us/autonomous-machines/embedded-systems/jetson-thor/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/jetson-thor.jpg"
                          >NVIDIA Jetson AGX Thor</a
                        ></td
                      ><td>Edge processing</td></tr
                    >
                    <tr
                      ><td>Infrastructure</td><td>Outdoor cabinet</td><td
                        >Mounting + power supply</td
                      ></tr
                    >
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Drone -->
          <div class="eq-card mb-10">
            <div class="eq-card-icon eq-icon-accent">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"
                ></path>
              </svg>
            </div>
            <div class="eq-card-body">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-xl font-bold">Aerial Drone Node</h3>
                <span class="badge badge-accent">Aerial</span>
              </div>
              <p class="opacity-70 mb-4">
                A T650 drone platform equipped with LiDAR, camera, RTK
                positioning, and on-board AI for aerial perception.
              </p>
              <div class="overflow-x-auto">
                <table class="table table-xs">
                  <thead
                    ><tr><th>Component</th><th>Model</th><th>Details</th></tr
                    ></thead
                  >
                  <tbody>
                    <tr
                      ><td>Edge Compute</td><td
                        ><a
                          href="https://www.nvidia.com/en-us/autonomous-machines/embedded-systems/jetson-orin/"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/jetson-orin.jpg"
                          >NVIDIA Jetson AGX Orin</a
                        ></td
                      ><td>32 GB, 1 TB SSD</td></tr
                    >
                    <tr
                      ><td>LiDAR</td><td
                        ><a
                          href="https://ouster.com/products/hardware/os0-lidar-sensor"
                          target="_blank"
                          class="link link-hover eq-preview"
                          data-preview="/images/equipment/ouster-os0.png"
                          >Ouster OS0-32 Rev7</a
                        ></td
                      ><td>Wide-FOV, short-range</td></tr
                    >
                    <tr
                      ><td>Camera</td><td
                        ><a
                          href="https://www.teledynevisionsolutions.com/en-150/products/blackfly-s-gige/?model=BFS-PGE-31S4C-C&vertical=machine%20vision&segment=iis"
