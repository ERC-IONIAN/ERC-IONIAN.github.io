---
import SiteNavbar from '../components/SiteNavbar.astro';

interface Props {
  title: string;
  memberName: string;
  memberRole?: string;
  memberPic?: string;
  memberAffiliation?: string;
  slug: string;
  links?: { title: string; url: string; icon?: string }[];
  activeTab?: string;
}

const {
  title,
  memberName,
  memberRole,
  memberPic,
  memberAffiliation,
  slug,
  links,
  activeTab = 'home',
} = Astro.props;
const siteTitle = 'IONIAN';
const pageTitle = `${title} | ${siteTitle}`;

const tabs = [
  { id: 'home', label: 'Home', href: `/team/${slug}/` },
  { id: 'research', label: 'Research', href: `/team/${slug}/research/` },
  { id: 'papers', label: 'Papers', href: `/team/${slug}/papers/` },
  { id: 'cv', label: 'CV', href: `/team/${slug}/cv/` },
];

const iconSvgs: Record<string, string> = {
  email:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>',
  twitter:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22.46 6c-.77.35-1.6.58-2.46.69a4.3 4.3 0 001.88-2.38 8.59 8.59 0 01-2.72 1.04 4.28 4.28 0 00-7.32 3.91A12.16 12.16 0 013.16 4.86a4.28 4.28 0 001.32 5.71 4.24 4.24 0 01-1.94-.53v.05a4.28 4.28 0 003.43 4.19 4.28 4.28 0 01-1.93.07 4.29 4.29 0 004 2.97A8.59 8.59 0 012 19.54a12.13 12.13 0 006.56 1.92c7.88 0 12.2-6.53 12.2-12.2 0-.19 0-.37-.01-.56A8.72 8.72 0 0024 5.06a8.57 8.57 0 01-2.54.7z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>',
  facebook:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>',
  scholar:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z"/></svg>',
  orcid:
    '<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-3.919-3.722h-2.4z"/></svg>',
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={`${memberName} — IONIAN, ETRO, VUB`} />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='45' fill='%23ccc'/></svg>"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400;1,700&family=Source+Sans+Pro:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body
    class="bg-base-100 text-base-content font-sans min-h-screen flex flex-col"
  >
    <SiteNavbar />

    <!-- Drawer layout -->
    <div class="bg-base-100 drawer lg:drawer-open flex-1">
      <input id="member-drawer" type="checkbox" class="drawer-toggle" />

      <!-- Main content -->
      <div class="drawer-content bg-base-100">
        <!-- Secondary bar (mobile sidebar toggle) -->
        <div class="bg-base-100 text-base-content shadow-sm lg:hidden">
          <nav class="navbar py-0 min-h-0">
            <div class="navbar-start">
              <label for="member-drawer" class="btn btn-ghost btn-sm">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  class="size-5 stroke-current"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
                </svg>
                <span class="text-sm">{memberName}</span>
              </label>
            </div>
          </nav>
        </div>

        <main
          class="p-8 pt-10 lg:pt-16 lg:max-w-5xl max-w-full mx-auto min-h-screen flex flex-col justify-between"
        >
          <div>
            <slot />
          </div>
        </main>
      </div>

      <!-- Sidebar -->
      <div class="drawer-side z-40">
        <label
          for="member-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <aside
          class="px-4 pt-4 w-[20rem] text-base-content flex flex-col member-sidebar h-screen sticky top-0"
        >
          <div class="flex flex-col my-8 justify-between h-full">
            <div>
              <div class="flex justify-center items-center flex-col">
                {
                  memberPic && (
                    <img
                      src={memberPic}
                      alt={memberName}
                      class="mask mask-circle size-44 object-cover"
                    />
                  )
                }
                <h1 class="text-lg font-black mt-6 hidden lg:block text-center">
                  {
                    memberRole && (
                      <span class="font-normal text-sm opacity-60 block">
                        {memberRole}
                      </span>
                    )
                  }
                  {memberName}
                </h1>
                {
                  memberAffiliation && (
                    <p class="text-xs opacity-50 mt-2 text-center hidden lg:block">
                      {memberAffiliation}
                    </p>
                  )
                }
                {
                  links && links.length > 0 && (
                    <div class="flex flex-wrap gap-1 items-center justify-center mt-3">
                      {links.map((link) => (
                        <a
                          href={link.url}
                          target="_blank"
                          title={link.title}
                          class="size-10 inline-flex items-center justify-center rounded-xl hover:bg-primary/20 transition-all duration-300"
                        >
                          {link.icon && iconSvgs[link.icon] ? (
                            <Fragment set:html={iconSvgs[link.icon]} />
                          ) : (
                            link.title
                          )}
                        </a>
                      ))}
                    </div>
                  )
                }
              </div>
              <div class="mx-4 mt-12">
                <ul class="space-y-4 menu grow shrink menu-md overflow-y-auto">
                  {
                    tabs.map((tab) => (
                      <li>
                        <a
                          href={tab.href}
                          class:list={[
                            'text-lg',
                            { active: activeTab === tab.id },
                          ]}
                        >
                          {tab.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </body>
</html>

<script>
  import { themeChange } from 'theme-change';
  themeChange();
</script>

<style is:global>
  @import '../styles/global.css';
</style>
